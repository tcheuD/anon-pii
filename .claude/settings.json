{
  "permissions": {
    "allow": [
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo run:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo check:*)",
      "Bash(cargo deny check:*)",
      "Bash(cargo --version:*)",
      "Bash(rustc:*)",
      "Bash(rustup update:*)",
      "Bash(./target/release/anon:*)",
      "Bash(git ls-tree:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Bash(pgrep:*)",
      "Skill(review-security)",
      "Skill(remove-slop)",
      "WebSearch",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:microsoft.github.io)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if printf '%s' \"$TOOL_INPUT\" | grep -q '\\.rs\"'; then cargo fmt --all --quiet 2>/dev/null; fi; exit 0",
            "statusMessage": "Formatting Rust code"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if printf '%s' \"$TOOL_INPUT\" | grep -qE 'mapping\\.json|\\.env'; then echo 'BLOCK: This file contains secrets or runtime state — do not edit directly.' >&2; exit 2; fi"
          }
        ]
      }
    ]
  }
}
